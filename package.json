    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "knip": "^6.3.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.2",
